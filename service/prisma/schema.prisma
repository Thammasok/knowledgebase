// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "main"]
}

/**
 * --------------------------------------------------------------------
 */
/**
 * Accounts
 */
/**
 * --------------------------------------------------------------------
 */

model Accounts {
  id                String   @id @unique @default(ulid())
  displayName       String   @db.VarChar(255)
  firstName         String?  @db.VarChar(255)
  lastName          String?  @db.VarChar(255)
  email             String   @unique @db.VarChar(255)
  password          String   @db.Text
  image             String?  @db.Text
  isExternalAccount Boolean? @default(false)
  externalProvider  String?  @db.VarChar(255)
  source            String?  @db.VarChar(255)
  isVerify          Boolean  @default(false)
  isRemove          Boolean  @default(false)
  tier              Tier     @default(free)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relation
  accountForgotPassword AccountForgotPassword?
  authSessions          AuthSession[]
  accountSetting        AccountSetting?
  workspaces            Workspace[]
  pageVersions          PageVersion[]
  workspaceMemberships  WorkspaceMember[]
  sentInvitations       WorkspaceInvitation[] @relation("InvitedBy")

  // Mapping
  @@map("accounts")
  @@schema("main")
}

model AccountRequestAccess {
  id        String   @id @unique @default(ulid())
  email     String   @unique @db.VarChar(255)
  allowed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Mapping
  @@map("account_request_access")
  @@schema("main")
}

model AccountForgotPassword {
  accountId String   @unique @db.VarChar(128)
  token     String   @db.VarChar(128)
  expiredAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  account Accounts @relation(fields: [accountId], references: [id])

  // Mapping
  @@map("account_forgot_passwords")
  @@schema("main")
}

model AuthSession {
  id        String   @id @default(uuid())
  accountId String   @db.VarChar(128)
  deviceId  String?  @db.VarChar(128)
  ip        String?  @db.VarChar(128)
  userAgent String?  @db.Text
  ipInfo    String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  account Accounts @relation(fields: [accountId], references: [id])

  // Mapping
  @@map("auth_sessions")
  @@schema("main")
}

model AccountSetting {
  accountId String   @unique @db.VarChar(128)
  language  String   @default("en")
  theme     Theme    @default(system)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  account Accounts @relation(fields: [accountId], references: [id])

  // Mapping
  @@map("account_settings")
  @@schema("main")
}

/**
 * --------------------------------------------------------------------
 */
/**
 * Workspaces
 */
/**
 * --------------------------------------------------------------------
 */

model Workspace {
  id         String   @id @unique @default(ulid())
  accountId  String   @db.VarChar(128)
  name       String   @db.VarChar(255)
  logo       String?  @db.VarChar(128)
  color      String   @default("#18181b") @db.VarChar(32)
  blockCount Int      @default(0)
  isRemove   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relation
  account     Accounts              @relation(fields: [accountId], references: [id])
  folders     Folder[]
  pages       Page[]
  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]

  // Mapping
  @@map("workspaces")
  @@schema("main")
}

model WorkspaceMember {
  id          String        @id @unique @default(ulid())
  workspaceId String        @db.VarChar(128)
  accountId   String        @db.VarChar(128)
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relation
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  account   Accounts  @relation(fields: [accountId], references: [id])

  // Mapping
  @@unique([workspaceId, accountId])
  @@index([workspaceId])
  @@map("workspace_members")
  @@schema("main")
}

model WorkspaceInvitation {
  id          String           @id @unique @default(ulid())
  workspaceId String           @db.VarChar(128)
  email       String           @db.VarChar(255)
  role        WorkspaceRole    @default(member)
  token       String           @unique @db.VarChar(128)
  status      InvitationStatus @default(pending)
  invitedById String           @db.VarChar(128)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relation
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  invitedBy Accounts  @relation("InvitedBy", fields: [invitedById], references: [id])

  // Mapping
  @@index([workspaceId])
  @@index([token])
  @@map("workspace_invitations")
  @@schema("main")
}

model Folder {
  id          String   @id @unique @default(ulid())
  workspaceId String   @db.VarChar(128)
  parentId    String?  @db.VarChar(128)
  name        String   @db.VarChar(255)
  depth       Int      @default(0)
  order       Int      @default(0)
  isRemove    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  parent    Folder?   @relation("FolderChildren", fields: [parentId], references: [id])
  children  Folder[]  @relation("FolderChildren")
  pages     Page[]

  // Mapping
  @@index([workspaceId, parentId])
  @@map("folders")
  @@schema("main")
}

model Page {
  id           String   @id @unique @default(ulid())
  workspaceId  String   @db.VarChar(128)
  folderId     String?  @db.VarChar(128)
  parentPageId String?  @db.VarChar(128)
  title        String   @default("Untitled") @db.VarChar(500)
  content      Json     @default("[]")
  depth        Int      @default(0)
  order        Int      @default(0)
  isRemove     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relation
  workspace  Workspace     @relation(fields: [workspaceId], references: [id])
  folder     Folder?       @relation(fields: [folderId], references: [id])
  parent     Page?         @relation("PageChildren", fields: [parentPageId], references: [id])
  children   Page[]        @relation("PageChildren")
  versions   PageVersion[]

  // Mapping
  @@index([workspaceId, folderId])
  @@index([workspaceId, parentPageId])
  @@map("pages")
  @@schema("main")
}

model PageVersion {
  id        String   @id @unique @default(ulid())
  pageId    String   @db.VarChar(128)
  accountId String   @db.VarChar(128)
  content   Json
  createdAt DateTime @default(now())

  // Relation
  page    Page     @relation(fields: [pageId], references: [id])
  account Accounts @relation(fields: [accountId], references: [id])

  // Mapping
  @@index([pageId])
  @@map("page_versions")
  @@schema("main")
}

enum Theme {
  light
  dark
  system

  // Mapping
  @@schema("main")
}

enum Tier {
  free
  personal
  startup

  // Mapping
  @@schema("main")
}

enum WorkspaceRole {
  owner
  member
  viewer

  // Mapping
  @@schema("main")
}

enum InvitationStatus {
  pending
  accepted
  expired

  // Mapping
  @@schema("main")
}
