NODE_ENV=development
PORT=3030

# Enable API Testing
# Mock req.auth
ENABLE_API_TEST=false

# Database
DATABASE_URL=
DATABASE_MONGO_URL=
DATABASE_REDIS_URL=

#JWT
JWT_SECRET=super-secret
ACCESS_TOKEN_EXPIRES_IN=1H
REFRESH_TOKEN_EXPIRES_IN=7D

# Mail — SMTP (Mailtrap for dev, any SMTP for production)
# Mailtrap sandbox: https://mailtrap.io → Inboxes → SMTP Settings
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false

# Mail sender identity
MAIL_DEFAULT_FROM_EMAIL=
MAIL_DEFAULT_FROM_NANE=

# Front-end Link
RESET_PASSWORD_URL=

# ALLOWED_ORIGIN_CLIENT_URL
ALLOWED_ORIGIN_CLIENT_URL=

# AWS
# S3
AWS_S3_END_POINT=
AWS_S3_REGION=
AWS_S3_BUCKET_NAME=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=

# IP APIs
IP_API_URL=https://freeipapi.com/api/json

# ADMIN_LIST
ADMIN_LIST=