{
  "name": "knowledgebase-all-service",
  "version": "1.0.0",
  "description": "CRM for Sale",
  "private": true,
  "keywords": [
    "Insurance",
    "CRM"
  ],
  "author": "Charanchai",
  "license": "ISC",
  "scripts": {
    "build": "npx tsc",
    "start": "node ./dist/src/server.js",
    "dev": "ts-node-dev -r tsconfig-paths/register src/server.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register ./node_modules/jest/bin/jest.js --runInBand",
    "pre-commit": "lint-staged",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:mig:init": "prisma migrate dev --name init --schema prisma/schema.prisma",
    "prisma:mig:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:test:deploy": "dotenv -e .env.test -- prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "ts-node src/seeds/seed.ts",
    "prisma:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.4.2",
    "@sendgrid/mail": "^8.1.4",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-useragent": "^1.0.15",
    "formidable": "^3.5.1",
    "hbs": "^4.2.0",
    "http-errors": "~1.6.3",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "mailtrap": "^4.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer-express-handlebars": "^6.1.2",
    "otp-generator": "^4.0.1",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.1.1",
    "ts-node-dev": "^2.0.0",
    "uuid": "^10.0.0",
    "uuidv7": "^1.0.1"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.24.7",
    "@dep-tree/cli": "^0.23.0",
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^9.1.1",
    "@faker-js/faker": "^10.0.0",
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/express-useragent": "^1.0.5",
    "@types/formidable": "^3.4.5",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^20.12.7",
    "@types/nodemailer-express-handlebars": "^4.0.5",
    "@types/otp-generator": "^4.0.2",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@dep-tree/cli",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ],
    "onlyBuiltDependencies": [
      "@dep-tree/cli",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
