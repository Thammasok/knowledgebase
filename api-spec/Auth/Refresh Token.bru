meta {
  name: Refresh Token
  type: http
  seq: 6
}

post {
  url: {{SERVICE_URL}}/api/v1/auth/refresh
  body: none
  auth: bearer
}

auth:bearer {
  token: {{USER_AUTH_REFRESH_TOKEN}}
}

script:post-response {
  if (res.status === 200) {
    const response = res.getBody();
     bru.setVar("USER_AUTH_ACCESS_TOKEN", response.token.accessToken);
     bru.setVar("USER_AUTH_REFRESH_TOKEN", response.token.refreshToken);
  }
}
